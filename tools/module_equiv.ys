# Module-level formal equivalence check
# Compares each RTL module against its extracted gate-level counterpart
# Usage: yosys -c tools/module_equiv.ys

# Load PDK blackboxes
read_verilog -sv \
  /Users/jiuri/tools/pdks/volare/sky130/versions/0fe599b2afb6708d281543108caf8310912f54af/sky130A/libs.ref/sky130_fd_sc_hd/verilog/sky130_fd_sc_hd__blackbox.v

# ── ALU equivalence ──
design -reset
read_verilog -sv rtl/alu.v gate_modules/alu_gate.v
proc
rename alu gold
rename alu_gate gate
equiv_make gold gate alu_equiv
prep -top alu_equiv
clk2fflogic
async2sync
equiv_induct -seq 4 -ignore-unknown-cells alu_equiv
equiv_status -assert alu_equiv

